# EventGraphDB Environment Configuration

# LLM API Key (required for claim extraction + planning)
LLM_API_KEY=sk-your-api-key-here

# LLM Model (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

# NER Service URL (REQUIRED - NER service on separate server)
# Replace with your NER service's IP address or hostname
NER_SERVICE_URL=http://192.168.1.100:8081/ner

# NER Request Timeout (optional, default: 5000ms)
NER_REQUEST_TIMEOUT_MS=5000

# Server Configuration (optional)
# RUST_LOG=info
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080

# Storage Configuration (optional)
# REDB_CACHE_SIZE_MB=256
# MEMORY_CACHE_SIZE=10000
# STRATEGY_CACHE_SIZE=5000
