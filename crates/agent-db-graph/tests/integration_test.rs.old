#[tokio::test]
async fn test_end_to_end_self_evolution_pipeline() -> Result<(), Box<dyn std::error::Error>> {
    println!("\n🧪 Testing Complete Self-Evolution Pipeline...");
    println!("   Event → Episode → Memory → Strategy → Reinforcement → Policy Guide");

    // Initialize all components
    let mut episode_detector = EpisodeDetector::new(EpisodeDetectorConfig {
        inactivity_threshold_ms: 2000,
        min_episode_length: 2,
        max_episode_length: 100,
        significance_threshold: 0.3,
    });

    let mut memory_formation = MemoryFormation::new(MemoryFormationConfig {
        min_episode_significance: 0.5,
        initial_strength: 0.7,
        access_strength_boost: 0.1,
        decay_rate: 0.01,
        max_strength: 1.0,
        min_strength_for_consolidation: 0.8,
    });

    let mut strategy_extractor = StrategyExtractor::new(StrategyExtractionConfig {
        min_significance: 0.5,
        min_success_rate: 0.7,
        min_occurrences: 1,
        max_strategies_per_agent: 100,
    });

    let mut inference = GraphInference::new(InferenceConfig::default());

    // Step 1: Create and process events
    println!("\n   Step 1: Processing events...");
    let context = create_test_context();
    let base_time = current_timestamp();

    let events = vec![
        create_cognitive_event(
            1,
            "self-learning-agent".to_string(),
            1,
            &context,
            base_time,
            vec![
                "Analyze error: TypeError in function call".to_string(),
                "Check parameter types".to_string(),
                "Add type guard for null values".to_string(),
                "Run tests to verify fix".to_string(),
            ],
        ),
        create_test_event(1, "self-learning-agent".to_string(), 1, &context, base_time + 500_000_000),
        create_test_event(1, "self-learning-agent".to_string(), 1, &context, base_time + 1_000_000_000),
    ];

    // Step 2: Episode detection
    println!("   Step 2: Detecting episodes...");
    for event in &events {
        episode_detector.process_event(event);
    }

    let episodes = episode_detector.get_completed_episodes();
    assert!(!episodes.is_empty(), "Should detect episodes");
    println!("      ✓ Episodes detected: {}", episodes.len());

    let mut episode = episodes[0].clone();
    episode.significance = 0.8;
    episode.outcome = Some(EpisodeOutcome::Success);

    // Step 3: Memory formation
    println!("   Step 3: Forming memories...");
    let memory_id = memory_formation.form_from_episode(&episode, &events);
    assert!(memory_id.is_some(), "Should form memory");
    println!("      ✓ Memory formed: {:?}", memory_id);

    // Step 4: Strategy extraction
    println!("   Step 4: Extracting strategies...");
    let strategy_id = strategy_extractor.extract_from_episode(&episode, &events)?;
    assert!(strategy_id.is_some(), "Should extract strategy");
    println!("      ✓ Strategy extracted: {:?}", strategy_id);

    let strategies = strategy_extractor.get_agent_strategies(1, 10);
    assert!(!strategies.is_empty(), "Should have strategies");
    println!("      ✓ Reasoning steps in strategy: {}", strategies[0].reasoning_steps.len());

    // Step 5: Reinforcement learning
    println!("   Step 5: Reinforcement learning...");
    let metrics = EpisodeMetrics {
        duration_seconds: 1.5,
        expected_duration_seconds: 2.0,
        quality_score: Some(0.95),
        custom_metrics: HashMap::new(),
    };

    let reinforcement_result = inference.reinforce_patterns(&episode, true, Some(metrics)).await?;
    println!("      ✓ Patterns strengthened: {}", reinforcement_result.patterns_strengthened);
    println!("      ✓ Patterns updated: {}", reinforcement_result.patterns_updated);

    // Step 6: Retrieve and apply learnings
    println!("   Step 6: Testing retrieval and application...");
    let retrieved_memories = memory_formation.retrieve_by_context(&context, 5);
    assert!(!retrieved_memories.is_empty(), "Should retrieve relevant memories");
    println!("      ✓ Memories retrieved: {}", retrieved_memories.len());

    // Summary
    println!("\n   ✅ COMPLETE PIPELINE TEST PASSED!");
    println!("   ═══════════════════════════════════");
    println!("   Events processed:       {}", events.len());
    println!("   Episodes detected:      {}", episodes.len());
    println!("   Memories formed:        {}", retrieved_memories.len());
    println!("   Strategies extracted:   {}", strategies.len());
    println!("   Reasoning steps:        {}", strategies[0].reasoning_steps.len());
    println!("   Patterns reinforced:    {}", reinforcement_result.patterns_strengthened);
    println!("   ═══════════════════════════════════");

    Ok(())
}