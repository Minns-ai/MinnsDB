#[tokio::test]
async fn test_episode_detection_and_completion() -> Result<(), Box<dyn std::error::Error>> {
    println!("\n🧪 Testing Episode Detection...");

    let config = EpisodeDetectorConfig {
        inactivity_threshold_ms: 2000,
        min_episode_length: 2,
        max_episode_length: 100,
        significance_threshold: 0.3,
    };

    let mut detector = EpisodeDetector::new(config);
    let context = create_test_context();
    let base_time = current_timestamp();

    // Create a sequence of events that form an episode
    let events = vec![
        create_test_event(1, "debug-agent".to_string(), 1, &context, base_time),
        create_cognitive_event(
            1,
            "debug-agent".to_string(),
            1,
            &context,
            base_time + 500_000_000,
            vec!["Check TypeScript error".to_string(), "Add null check".to_string()],
        ),
        create_test_event(1, "debug-agent".to_string(), 1, &context, base_time + 1_000_000_000),
    ];

    // Process events through detector
    let mut episode_id = None;
    for event in &events {
        if let Some(completed_id) = detector.process_event(event) {
            episode_id = Some(completed_id);
        }
    }

    // Force completion by inactivity
    tokio::time::sleep(Duration::from_millis(100)).await;
    let final_event = create_test_event(
        1,
        "debug-agent".to_string(),
        1,
        &context,
        base_time + 5_000_000_000
    );
    if let Some(completed_id) = detector.process_event(&final_event) {
        episode_id = Some(completed_id);
    }

    // Verify episode was created
    let episodes = detector.get_completed_episodes();
    assert!(!episodes.is_empty(), "Should have at least one completed episode");

    let episode = &episodes[0];
    assert_eq!(episode.agent_id, 1, "Episode should belong to agent 1");
    assert!(episode.events.len() >= 2, "Episode should contain multiple events");
    assert!(episode.significance > 0.0, "Episode should have significance score");

    println!("✅ Episode detection test passed!");
    println!("   - Episodes detected: {}", episodes.len());
    println!("   - Events in episode: {}", episode.events.len());
    println!("   - Significance: {:.2}", episode.significance);

    Ok(())
}

#[tokio::test]
async fn test_memory_formation_and_retrieval() -> Result<(), Box<dyn std::error::Error>> {
    println!("\n🧪 Testing Memory Formation...");

    let config = MemoryFormationConfig {
        min_episode_significance: 0.5,
        initial_strength: 0.7,
        access_strength_boost: 0.1,
        decay_rate: 0.01,
        max_strength: 1.0,
        min_strength_for_consolidation: 0.8,
    };

    let mut memory_formation = MemoryFormation::new(config);

    // Create episode detector and process events
    let detector_config = EpisodeDetectorConfig::default();
    let mut detector = EpisodeDetector::new(detector_config);

    let context = create_test_context();
    let base_time = current_timestamp();

    let events = vec![
        create_cognitive_event(
            1,
            "code-reviewer".to_string(),
            1,
            &context,
            base_time,
            vec![
                "Check for null safety".to_string(),
                "Verify error handling".to_string(),
                "Ensure type consistency".to_string(),
            ],
        ),
        create_test_event(1, "code-reviewer".to_string(), 1, &context, base_time + 500_000_000),
        create_test_event(1, "code-reviewer".to_string(), 1, &context, base_time + 1_000_000_000),
    ];

    // Process events to create episode
    for event in &events {
        detector.process_event(event);
    }

    // Get completed episodes
    let episodes = detector.get_completed_episodes();
    assert!(!episodes.is_empty(), "Should have created episode");

    let episode = &episodes[0];

    // Set high significance to trigger memory formation
    let mut significant_episode = episode.clone();
    significant_episode.significance = 0.75;
    significant_episode.outcome = Some(EpisodeOutcome::Success);

    // Form memory from episode
    let memory_id = memory_formation.form_from_episode(&significant_episode, &events);
    assert!(memory_id.is_some(), "Should create memory from significant episode");

    // Retrieve memory by context
    let retrieved = memory_formation.retrieve_by_context(&context, 5);
    assert!(!retrieved.is_empty(), "Should retrieve memories by context");

    let memory = &retrieved[0];
    assert_eq!(memory.memory_type, MemoryType::Episodic, "Should be episodic memory");
    assert!(memory.strength >= 0.7, "Memory should have initial strength");
    assert_eq!(memory.access_count, 1, "Should have been accessed once during retrieval");

    // Test memory decay
    memory_formation.decay_memories();
    let stats = memory_formation.get_stats();

    println!("✅ Memory formation test passed!");
    println!("   - Memories formed: {}", stats.total_memories);
    println!("   - Episodic memories: {}", stats.episodic_memories);
    println!("   - Average strength: {:.2}", stats.average_strength);

    Ok(())
}

#[tokio::test]
async fn test_strategy_extraction_from_episodes() -> Result<(), Box<dyn std::error::Error>> {
    println!("\n🧪 Testing Strategy Extraction...");

    let config = StrategyExtractionConfig {
        min_significance: 0.6,
        min_success_rate: 0.7,
        min_occurrences: 1, // Lower for testing
        max_strategies_per_agent: 100,
    };

    let mut extractor = StrategyExtractor::new(config);

    // Create successful episode with reasoning traces
    let context = create_test_context();
    let base_time = current_timestamp();

    let events = vec![
        create_cognitive_event(
            1,
            "test-generator".to_string(),
            1,
            &context,
            base_time,
            vec![
                "Identify test cases from function signature".to_string(),
                "Generate edge cases for null inputs".to_string(),
                "Add assertion for expected behavior".to_string(),
                "Verify test coverage metrics".to_string(),
            ],
        ),
        create_test_event(1, "test-generator".to_string(), 1, &context, base_time + 500_000_000),
    ];

    // Create episode
    let mut detector = EpisodeDetector::new(EpisodeDetectorConfig::default());
    for event in &events {
        detector.process_event(event);
    }

    let episodes = detector.get_completed_episodes();
    let mut episode = episodes[0].clone();

    // Mark as successful and significant
    episode.outcome = Some(EpisodeOutcome::Success);
    episode.significance = 0.85;

    // Extract strategy
    let strategy_id = extractor.extract_from_episode(&episode, &events)?;
    assert!(strategy_id.is_some(), "Should extract strategy from successful episode");

    // Retrieve strategies for agent
    let strategies = extractor.get_agent_strategies(1, 10);
    assert!(!strategies.is_empty(), "Should have strategies for agent");

    let strategy = strategies[0];
    assert_eq!(strategy.agent_id, 1, "Strategy should belong to agent 1");
    assert!(!strategy.reasoning_steps.is_empty(), "Strategy should have reasoning steps");
    assert_eq!(strategy.reasoning_steps.len(), 4, "Should extract all reasoning steps");
    assert!(strategy.quality_score >= 0.8, "Strategy should have high quality score");

    // Test strategy outcome update
    let sid = strategy_id.unwrap();
    extractor.update_strategy_outcome(sid, true)?;

    let stats = extractor.get_stats();

    println!("✅ Strategy extraction test passed!");
    println!("   - Strategies extracted: {}", stats.total_strategies);
    println!("   - High quality strategies: {}", stats.high_quality_strategies);
    println!("   - Reasoning steps: {}", strategy.reasoning_steps.len());
    println!("   - Quality score: {:.2}", strategy.quality_score);

    Ok(())
}

#[tokio::test]
async fn test_reinforcement_learning_from_outcomes() -> Result<(), Box<dyn std::error::Error>> {
    println!("\n🧪 Testing Reinforcement Learning...");

    let config = InferenceConfig::default();
    let mut inference = GraphInference::new(config);

    // Create episode
    let context = create_test_context();
    let base_time = current_timestamp();

    let events = vec![
        create_test_event(1, "debugger".to_string(), 1, &context, base_time),
        create_test_event(1, "debugger".to_string(), 1, &context, base_time + 500_000_000),
        create_test_event(1, "debugger".to_string(), 1, &context, base_time + 1_000_000_000),
    ];

    let mut detector = EpisodeDetector::new(EpisodeDetectorConfig::default());
    for event in &events {
        detector.process_event(event);
    }

    let episodes = detector.get_completed_episodes();
    let mut episode = episodes[0].clone();
    episode.outcome = Some(EpisodeOutcome::Success);

    // Test reinforcement with success
    let metrics = EpisodeMetrics {
        duration_seconds: 2.5,
        expected_duration_seconds: 3.0,
        quality_score: Some(0.9),
        custom_metrics: HashMap::new(),
    };

    let result = inference.reinforce_patterns(&episode, true, Some(metrics)).await?;

    assert!(result.patterns_strengthened > 0 || result.patterns_updated >= 0,
            "Should strengthen or update patterns");

    println!("   - Patterns strengthened: {}", result.patterns_strengthened);
    println!("   - Patterns updated: {}", result.patterns_updated);

    // Test reinforcement with failure
    let mut failed_episode = episode.clone();
    failed_episode.outcome = Some(EpisodeOutcome::Failure);

    let failure_result = inference.reinforce_patterns(&failed_episode, false, None).await?;

    assert!(failure_result.patterns_weakened > 0 || failure_result.patterns_updated >= 0,
            "Should weaken or update patterns on failure");

    println!("   - Patterns weakened: {}", failure_result.patterns_weakened);

    // Check reinforcement stats
    let stats = inference.get_reinforcement_stats();

    println!("✅ Reinforcement learning test passed!");
    println!("   - Total patterns: {}", stats.total_patterns);
    println!("   - High confidence: {}", stats.high_confidence_patterns);
    println!("   - Average confidence: {:.2}", stats.average_confidence);

    Ok(())
}

